# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
# Generally, node_modules should be ignored at the root
# You may choose to ignore them in individual workspaces if not hoisted
node_modules
/.pnp
.pnp.js
**/dist

# Testing
/coverage

# Next.js
# These are the build artifacts for Next.js applications
.next/
/out/
# It is recommended to add next-env.d.ts to your .gitignore
next-env.d.ts

# Production
/build

# Monorepo tools (e.g., Turborepo)
# Turborepo uses a .turbo folder for caching artifacts
.turbo/

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment files
.env*.local
.env

# Vercel
# Vercel deployment artifacts
.vercel

# TypeScript
# tsbuildinfo files are generated by TypeScript
*.tsbuildinfo
